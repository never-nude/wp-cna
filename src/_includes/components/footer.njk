<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <p class="footer-brand">{{ site.shortName }}</p>
      <p>{{ site.mission }}</p>
    </div>
    <div>
      <h3>Contact</h3>
      <ul>
        <li>{{ site.contactName }}</li>
        <li>{{ site.location }}</li>
        <li><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
      </ul>
    </div>
    <div>
      <h3>Community</h3>
      <ul>
        {% for link in site.communityChannels %}
          <li><a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }}</a></li>
        {% endfor %}
        <li><a href="{{ site.currentSiteUrl }}" target="_blank" rel="noopener">WPCNA main site</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>{{ site.footerNote }}</p>
  </div>
</footer>
