{% macro eventCard(event, featured=false) %}
  <article
    class="event-card{% if featured %} event-card--featured{% endif %}"
    data-event-card
    data-category="{{ event.category }}"
    data-month="{{ event.monthKey }}"
    data-status="{{ event.status }}"
    data-search="{{ event.searchText }}"
  >
    {% if featured and event.displayImage %}
      <a class="event-card__media" href="{{ event.detailUrl | withPrefix }}" aria-hidden="true" tabindex="-1">
        <img src="{{ event.displayImage | withPrefix }}" alt="" loading="lazy">
      </a>
    {% endif %}
    <div class="event-card__body">
      <div class="event-card__topline">
        <div class="event-card__labels">
          <span class="tag">{{ event.category }}</span>
          {% if event.status == "past" %}
            <span class="event-card__status">Past event</span>
          {% endif %}
        </div>
        <span class="event-card__source">{{ event.organizer }}</span>
      </div>
      <h3><a href="{{ event.detailUrl | withPrefix }}">{{ event.title }}</a></h3>
      <p class="event-card__date">{{ event | shortDateLabel }}</p>
      <div class="event-card__meta" aria-label="Event details">
        <div class="event-card__meta-item">
          <span class="event-card__label">Time</span>
          <span>{{ event | timeLabel }}</span>
        </div>
        <div class="event-card__meta-item">
          <span class="event-card__label">Location</span>
          <span>{{ event.locationName }}</span>
        </div>
      </div>
      <p class="event-card__summary">{{ event.shortSummary }}</p>
      <div class="event-card__actions">
        {% if event.primaryAction %}
          <a class="button" href="{{ event.primaryAction.url }}" target="_blank" rel="noreferrer">
            {{ event.primaryAction.label }}
          </a>
        {% endif %}
        <a class="text-link" href="{{ event.detailUrl | withPrefix }}">See details</a>
      </div>
    </div>
  </article>
{% endmacro %}

{% macro resourceCard(resource) %}
  <article class="resource-card">
    <p class="eyebrow">{{ resource.eyebrow }}</p>
    <h3>{{ resource.title }}</h3>
    <p>{{ resource.summary }}</p>
    <a class="text-link" href="{{ resource.url }}" target="_blank" rel="noreferrer">{{ resource.ctaLabel }}</a>
  </article>
{% endmacro %}

{% macro neighborhoodCard(neighborhood) %}
  <article class="neighborhood-card">
    <div class="neighborhood-card__media">
      <img src="{{ neighborhood.image | withPrefix }}" alt="{{ neighborhood.imageAlt }}" loading="lazy">
    </div>
    <div class="neighborhood-card__body">
      <h3>{{ neighborhood.name }}</h3>
      <p>{{ neighborhood.summary }}</p>
    </div>
  </article>
{% endmacro %}
