---
layout: layouts/base.njk
title: Events
metaDescription: A selective calendar of events, meetings, and public life around White Plains.
pageClass: page-events
---
{% from "components/macros.njk" import eventCard %}

<section class="page-hero page-hero--compact">
  <div class="container page-hero__content">
    <p class="eyebrow">Events</p>
    <h1>Events in White Plains</h1>
    <p>A selective White Plains calendar, with upcoming events first and older listings below if you need them.</p>
  </div>
</section>

<section class="section section--flush-top">
  <div class="container">
    <form class="filter-bar" data-event-filters>
      <label>
        <span>Search</span>
        <input type="search" name="search" placeholder="Search by event, place, organizer, or tag">
      </label>

      <label>
        <span>Category</span>
        <select name="category">
          <option value="">All categories</option>
          {% for category in eventStore.categories %}
            <option value="{{ category }}">{{ category }}</option>
          {% endfor %}
        </select>
      </label>

      <label>
        <span>Month</span>
        <select name="month">
          <option value="">All months</option>
          {% for monthKey in eventStore.months %}
            <option value="{{ monthKey }}">{{ monthKey | monthYearLabel }}</option>
          {% endfor %}
        </select>
      </label>

      <button class="button button--ghost" type="reset">Clear filters</button>
    </form>
  </div>
</section>

<section class="section section--flush-top" data-event-section>
  <div class="container section__intro">
    <div>
      <p class="eyebrow">Coming Up</p>
      <h2>Here's what's coming up</h2>
      <p>This calendar is meant to stay readable. It pulls together the events most likely to matter to White Plains residents, rather than mirroring every source in full.</p>
    </div>
    <p class="section__count" data-event-count>{{ eventStore.upcoming.length }} events</p>
  </div>

  {% if eventStore.upcoming.length %}
    <div class="container card-grid">
      {% for event in eventStore.upcoming %}
        {{ eventCard(event) }}
      {% endfor %}
    </div>
  {% else %}
    <div class="container empty-state">
      <h3>Nothing is on the calendar right now.</h3>
      <p>Check back soon for the next White Plains event.</p>
    </div>
  {% endif %}

  <div class="container empty-state empty-state--inline" hidden data-filter-empty>
    <h3>Nothing matches that search.</h3>
    <p>Try a different word, month, category, or organizer.</p>
  </div>
</section>

<section class="section section--tint">
  <div class="container">
    <details class="archive-panel"{% if not eventStore.upcoming.length %} open{% endif %}>
      <summary>
        <span>
          <span class="eyebrow">Past Events</span>
          <strong>Past events</strong>
        </span>
        <span class="archive-panel__count">{{ eventStore.past.length }} events</span>
      </summary>

      <div class="archive-panel__content" data-event-section>
        <p class="archive-panel__intro">Older listings stay here for reference without crowding out what is coming up next.</p>
        <div class="card-grid card-grid--past">
          {% for event in eventStore.past %}
            {{ eventCard(event) }}
          {% endfor %}
        </div>
        <div class="empty-state empty-state--inline" hidden data-filter-empty>
          <h3>Nothing in the archive matches that.</h3>
          <p>Try a broader search or clear the filters.</p>
        </div>
      </div>
    </details>
  </div>
</section>
