---
layout: layouts/base.njk
title: Local Events in White Plains
metaDescription: Find upcoming White Plains civic, family, cultural, and neighborhood events in a cleaner resident-first format from WPCNA.
pageClass: page-home
---
{% from "components/macros.njk" import eventCard, neighborhoodCard, resourceCard %}

<section class="hero hero--home">
  <div class="container hero__stack">
    <figure class="hero__frame">
      <img src="{{ site.heroImage | withPrefix }}" alt="{{ site.heroImageAlt }}" loading="eager">
      <div class="hero__overlay">
        <div class="hero__content">
          <p class="eyebrow">White Plains Council of Neighborhood Associations</p>
          <h1>White Plains events, organized for city life.</h1>
          <p class="hero__lede">Find civic meetings, neighborhood updates, workshops, and community events in one current, resident-friendly calendar.</p>
          <div class="hero__actions">
            <a class="button button--large" href="{{ '/events/' | withPrefix }}">View events</a>
            <a class="button button--ghost button--large" href="{{ '/about/' | withPrefix }}">About WPCNA</a>
          </div>
        </div>
        <figcaption class="hero__caption">
          <strong>{{ site.heroImageLabel }}</strong>
          <span>{{ site.heroImageSummary }}</span>
        </figcaption>
      </div>
    </figure>
    <ul class="hero__stats" aria-label="Site highlights">
      <li><span>Upcoming</span><strong>{{ eventStore.upcoming.length }}</strong></li>
      <li><span>Archive</span><strong>{{ eventStore.past.length }}</strong></li>
      <li><span>Every listing</span><strong>1 clear action</strong></li>
    </ul>
  </div>
</section>

<section class="section section--flush-top">
  <div class="container section__intro">
    <div>
      <p class="eyebrow">Featured Upcoming Events</p>
      <h2>Current events across White Plains</h2>
      <p>Each listing is structured around the essentials: title, date, location, and the one next step a resident should take.</p>
    </div>
    <a class="text-link" href="{{ '/events/' | withPrefix }}">View all events</a>
  </div>

  {% if eventStore.homeUpcoming.length %}
    <div class="container card-grid card-grid--featured">
      {% for event in eventStore.homeUpcoming %}
        {{ eventCard(event, true) }}
      {% endfor %}
    </div>
  {% else %}
    <div class="container empty-state">
      <h3>No upcoming events are posted right now.</h3>
      <p>Check back soon, browse the archive, or contact WPCNA for the latest neighborhood updates.</p>
      <a class="button" href="{{ '/events/' | withPrefix }}">Browse archived events</a>
    </div>
  {% endif %}
</section>

<section class="section section--tint">
  <div class="container section__intro">
    <div>
      <p class="eyebrow">Neighborhoods</p>
      <h2>Neighborhoods that shape White Plains</h2>
      <p>WPCNA works citywide, but its perspective starts with the neighborhoods and associations that give White Plains its local character.</p>
    </div>
  </div>
  <div class="container neighborhood-grid">
    {% for neighborhood in neighborhoods %}
      {{ neighborhoodCard(neighborhood) }}
    {% endfor %}
  </div>
</section>

<section class="section">
  <div class="container section__intro">
    <div>
      <p class="eyebrow">Get Involved</p>
      <h2>Useful civic links for residents and neighborhood leaders</h2>
      <p>Meeting materials, workshop resources, and neighborhood reference pages should stay accessible without competing with the event calendar.</p>
    </div>
  </div>
  <div class="container resource-grid">
    {% for resource in resources %}
      {{ resourceCard(resource) }}
    {% endfor %}
  </div>
</section>

<section class="section">
  <div class="container spotlight">
    <div>
      <p class="eyebrow">About WPCNA</p>
      <h2>A current civic front door for neighborhood life</h2>
      <p>{{ site.mission }}</p>
      <p>{{ site.meetingNote }}</p>
    </div>
    <div class="spotlight__card">
      <p class="eyebrow">Contact</p>
      <h3>{{ site.contactName }}</h3>
      <p>{{ site.location }}</p>
      <a class="button button--ghost" href="mailto:{{ site.email }}">Email WPCNA</a>
    </div>
  </div>
</section>
