---
layout: layouts/base.njk
title: What's Happening in White Plains
metaDescription: Local events, meetings, and things to know around White Plains.
pageClass: page-home
---
{% from "components/macros.njk" import eventCard, neighborhoodCard, resourceCard %}

<section class="hero hero--home">
  <div class="container hero__stack">
    <figure class="hero__frame">
      <img src="{{ site.heroImage | withPrefix }}" alt="{{ site.heroImageAlt }}" loading="eager">
      <div class="hero__overlay">
        <div class="hero__content">
          <p class="eyebrow">White Plains Council of Neighborhood Associations</p>
          <h1>What's happening in White Plains</h1>
          <p class="hero__lede">Local events, meetings, and things to know, all in one place.</p>
          <div class="hero__actions">
            <a class="button button--large" href="{{ '/events/' | withPrefix }}">View events</a>
            <a class="button button--ghost button--large" href="{{ '/about/' | withPrefix }}">About WPCNA</a>
          </div>
        </div>
      </div>
    </figure>
    <ul class="hero__stats" aria-label="Site highlights">
      <li><span>Coming up</span><strong>{{ eventStore.upcoming.length }}</strong></li>
      <li><span>Past events</span><strong>{{ eventStore.past.length }}</strong></li>
      <li><span>Each event</span><strong>1 clear next step</strong></li>
    </ul>
  </div>
</section>

<section class="section section--flush-top">
  <div class="container section__intro">
    <div>
      <p class="eyebrow">Coming Up</p>
      <h2>Here's what's happening</h2>
      <p>You can scan the basics fast: what it is, when it is, where it is, and what to click next.</p>
    </div>
    <a class="text-link" href="{{ '/events/' | withPrefix }}">See all events</a>
  </div>

  {% if eventStore.homeUpcoming.length %}
    <div class="container card-grid card-grid--featured">
      {% for event in eventStore.homeUpcoming %}
        {{ eventCard(event, true) }}
      {% endfor %}
    </div>
  {% else %}
    <div class="container empty-state">
      <h3>Nothing is posted right now.</h3>
      <p>Check back soon, look through past events, or email WPCNA if you're trying to track something specific.</p>
      <a class="button" href="{{ '/events/' | withPrefix }}">See past events</a>
    </div>
  {% endif %}
</section>

<section class="section section--tint">
  <div class="container section__intro">
    <div>
      <p class="eyebrow">Neighborhoods</p>
      <h2>White Plains neighborhoods</h2>
      <p>WPCNA covers the whole city, but neighborhood life is where a lot of White Plains starts.</p>
    </div>
  </div>
  <div class="container neighborhood-grid">
    {% for neighborhood in neighborhoods %}
      {{ neighborhoodCard(neighborhood) }}
    {% endfor %}
  </div>
</section>

<section class="section">
  <div class="container section__intro">
    <div>
      <p class="eyebrow">Useful Links</p>
      <h2>A few pages you may want</h2>
      <p>If you're looking for agendas, workshop materials, or the neighborhood map, start here.</p>
    </div>
  </div>
  <div class="container resource-grid">
    {% for resource in resources %}
      {{ resourceCard(resource) }}
    {% endfor %}
  </div>
</section>

<section class="section">
  <div class="container spotlight">
    <div>
      <p class="eyebrow">About WPCNA</p>
      <h2>Why this site exists</h2>
      <p>{{ site.mission }}</p>
      <p>{{ site.meetingNote }}</p>
    </div>
    <div class="spotlight__card">
      <p class="eyebrow">Contact</p>
      <h3>{{ site.contactName }}</h3>
      <p>{{ site.location }}</p>
      <a class="button button--ghost" href="mailto:{{ site.email }}">Email us</a>
    </div>
  </div>
</section>
