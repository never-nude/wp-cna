---
pagination:
  data: neighborhoodStore.all
  size: 1
  alias: neighborhood
permalink: "neighborhoods/{{ neighborhood.slug }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ neighborhood.name }}"
  metaDescription: "{{ neighborhood.metaDescription }}"
  ogImage: "{{ neighborhood.hero and neighborhood.hero.imagePath or site.defaultOgImage }}"
  pageClass: "page-neighborhood-detail"
---
<section class="page-hero page-hero--compact">
  <div class="container page-hero__shell{% if neighborhood.hero %} page-hero__shell--with-media{% endif %}">
    <div class="page-hero__content">
      <a class="back-link" href="{{ '/neighborhoods/' | withPrefix }}">Back to neighborhoods</a>
      <p class="eyebrow">{{ neighborhood.group }}</p>
      <h1>{{ neighborhood.name }}</h1>
      <p>{{ neighborhood.teaser }}</p>
    </div>

    {% if neighborhood.hero %}
      <figure class="page-hero__media page-hero__media--neighborhood">
        <img
          src="{{ neighborhood.hero.imagePath | withPrefix }}"
          alt="{{ neighborhood.hero.altText }}"
          loading="eager"
          decoding="async"
        >
        <figcaption class="page-hero__credit">
          <span>Photo: {{ neighborhood.hero.attributionText }}</span>
          <a href="{{ neighborhood.hero.attributionUrl }}" rel="external noopener">Source</a>
          <span>{{ neighborhood.hero.license }}</span>
        </figcaption>
      </figure>
    {% endif %}
  </div>
</section>

<section class="section section--flush-top">
  <div class="container detail-grid">
    <article class="detail-main">
      <div class="detail-copy">
        <div class="detail-copy__meta">
          <span class="tag">Neighborhood</span>
          <span>{{ neighborhood.group }}</span>
        </div>

        <h2>Local feel</h2>
        {% for paragraph in neighborhood.detailParagraphs %}
          <p>{{ paragraph }}</p>
        {% endfor %}

        <div class="detail-links">
          <h3>In the wider White Plains picture</h3>
          <p>{{ neighborhood.groupDescription }}</p>
          <p>{{ neighborhood.orientationNote }}</p>
        </div>
      </div>
    </article>

    <aside class="detail-sidebar">
      <div class="detail-card detail-card--stacked">
        <p class="eyebrow">At a Glance</p>
        <dl class="detail-list">
          <div>
            <dt>Neighborhood</dt>
            <dd>{{ neighborhood.name }}</dd>
          </div>
          <div>
            <dt>Section</dt>
            <dd>{{ neighborhood.group }}</dd>
          </div>
          {% if neighborhood.referencePoints.length %}
            <div>
              <dt>Local anchors</dt>
              <dd>{{ neighborhood.referencePoints | join(", ") }}</dd>
            </div>
          {% endif %}
          <div>
            <dt>City</dt>
            <dd>White Plains</dd>
          </div>
        </dl>

        <a class="button button--large button--block" href="{{ '/events/' | withPrefix }}">See White Plains events</a>
      </div>

      {% if neighborhood.relatedNeighborhoods.length %}
        <div class="detail-card detail-card--secondary">
          <p class="eyebrow">Nearby</p>
          <h2>Nearby neighborhoods</h2>
          <ul class="footer-list">
            {% for related in neighborhood.relatedNeighborhoods %}
              <li><a href="{{ related.detailUrl | withPrefix }}">{{ related.name }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </aside>
  </div>
</section>
